# ============================================================
# EquipPeer Backend - Environment Variables (copy to .env)
# ============================================================

# ---- Server ----
PORT=5000
# Set to "production" on deployment platforms
NODE_ENV=development

# ---- Frontend URL (used for VNPay return redirect) ----
# e.g. https://your-frontend.vercel.app  or  http://150.136.248.214
FRONTEND_URL=http://localhost:5173

# ---- Database (REQUIRED) ----
# Use MongoDB Atlas for cloud deploy, e.g.:
# mongodb+srv://<user>:<password>@<cluster>.mongodb.net/equippeer?retryWrites=true&w=majority
MONGODB_URI=mongodb://localhost:27017/equippeer

# ---- Auth ----
JWT_SECRET=change_this_to_a_long_random_secret
JWT_EXPIRES_IN=7d

# ---- Google OAuth (optional) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback

# ---- AI (optional) ----
GEMINI_API_KEY=

# ---- Payment: VNPay (required for real payments) ----
vnp_TmnCode=
vnp_HashSecret=
vnp_Url=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html
vnp_ReturnUrl=http://localhost:5000/api/orders/vnpay/return

# ---- SMS providers (choose one via SMS_PROVIDER) ----
SMS_PROVIDER=speedsms
SPEEDSMS_API_KEY=
SPEEDSMS_SENDER=
ESMS_API_KEY=
ESMS_SECRET_KEY=
ESMS_BRANDNAME=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# ---- Monitoring (optional) ----
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
